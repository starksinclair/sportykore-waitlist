---
import { Image } from 'astro:assets';
import WaitlistForm from '../components/WaitlistForm.astro';
import homeScreen from '../assets/screens/home-screen.png';
import onboardingScreen from '../assets/screens/onboarding-screen.png';
import loginScreen from '../assets/screens/login-screen.png';
import Layout from '../layouts/Layout.astro';

export const prerender = true;

const year = new Date().getFullYear();
---

<Layout
	title="Sportykore Waitlist | Where local leagues gather"
	description="Join the Sportykore waitlist to follow local matches, see clear stats, and stay close to the leagues shaping grassroots football in Nigeria."
	pathname="/"
>
	<main class="overflow-x-clip">
		<!-- Hero: app-style dark chrome + purple wash (design.md) -->
		<section class="relative isolate min-h-[min(100svh,56rem)] bg-[#121212] lg:min-h-[min(100svh,52rem)]">
			<div class="pointer-events-none absolute inset-0 hero-purple-wash"></div>
			<div
				class="pointer-events-none absolute inset-0 bg-linear-to-b from-black/30 via-transparent to-black/20"
			>
			</div>

			<div class="relative mx-auto max-w-6xl px-5 pb-24 pt-6 sm:px-8 sm:pb-28 sm:pt-8 lg:px-10 lg:pb-32">
				<header
					class="flex animate-hero-rise items-center justify-between gap-4 [animation-delay:0ms]"
				>
					<p class="font-brand text-[2.125rem] leading-none tracking-tight text-accent-400 sm:text-5xl">
						Sportykore
					</p>
					<div class="flex items-center gap-2 sm:gap-3">
						<span
							class="hidden rounded-full border border-white/10 bg-white/6 px-2.5 py-1 text-[9px] font-bold uppercase tracking-[0.28em] text-white/50 md:inline"
						>
							Waitlist
						</span>
					</div>
				</header>

				<div class="mt-12 grid gap-12 lg:mt-16 lg:grid-cols-12 lg:items-center lg:gap-10" id="form">
					<div
						class="animate-hero-rise max-w-xl space-y-6 lg:col-span-5 [animation-delay:70ms]"
					>
					<WaitlistForm variant="dark" />
					
						<h1
							class="font-display text-[2.625rem] font-bold leading-[1.06] tracking-tight text-white sm:text-5xl lg:text-[3.15rem]"
						>
							Where local leagues gather.
						</h1>
						<p class="max-w-md text-base leading-relaxed text-white/72 sm:text-[1.0625rem]">
							Local football with a broadcast-style feed. Track live minutes, follow leagues, and read stats built for organizers and fans.
						</p>

						<dl class="border-t border-white/10 pt-6">
							<div class="grid grid-cols-3 gap-3 sm:gap-6">
								<div>
									<dt class="text-[10px] font-semibold uppercase tracking-[0.18em] text-white/42">
										Focus
									</dt>
									<dd class="mt-1.5 text-[13px] font-semibold text-white">Live feed</dd>
								</div>
								<div>
									<dt class="text-[10px] font-semibold uppercase tracking-[0.18em] text-white/42">
										Clarity
									</dt>
									<dd class="mt-1.5 text-[13px] font-semibold text-white">Clear stats</dd>
								</div>
								<div>
									<dt class="text-[10px] font-semibold uppercase tracking-[0.18em] text-white/42">
										Scope
									</dt>
									<dd class="mt-1.5 text-[13px] font-semibold text-white">Local leagues</dd>
								</div>
							</div>
						</dl>
					</div>

					<div class="relative mx-auto w-full max-w-88 sm:max-w-md lg:col-span-7 lg:mx-0 lg:max-w-none">
						<div class="relative flex justify-center lg:justify-end">
							<div
								class="pointer-events-none absolute left-1/2 top-[18%] h-44 w-[min(100%,28rem)] -translate-x-1/2 rounded-full bg-brand-500/30 blur-3xl lg:left-auto lg:right-0 lg:translate-x-[10%]"
							>
							</div>

							<div class="animate-hero-float relative w-[82%] sm:w-[76%] lg:w-[min(100%,32rem)]">
								<div
									class="absolute left-[-10%] top-[6%] z-10 hidden w-[40%] md:block lg:left-[-4%] lg:top-[10%] lg:w-[32%]"
								>
									<div
										class="overflow-hidden rounded-[1.65rem] border border-white/14 bg-[#101012] p-2 shadow-phone"
									>
										<Image
											src={onboardingScreen}
											alt="Sportykore onboarding: real-time match data on a light card."
											loading="lazy"
											decoding="async"
											sizes="(min-width: 1024px) 200px, 0px"
											class="rounded-[1.2rem]"
										/>
									</div>
								</div>

								<div
									class="relative z-1 overflow-hidden rounded-[2.1rem] border border-white/14 bg-[#101012] p-[10px] shadow-phone ring-1 ring-black/50"
								>
									<Image
										src={loginScreen}
										alt="Sportykore home: matches, live tab, and league listings."
										loading="eager"
										fetchpriority="high"
										decoding="async"
										sizes="(min-width: 1280px) 400px, (min-width: 1024px) 38vw, 82vw"
										class="rounded-[1.35rem]"
									/>
								</div>

								<div
									class="absolute right-[-8%] bottom-[5%] z-10 hidden w-[38%] md:block lg:right-[-2%] lg:bottom-[8%] lg:w-[30%]"
								>
									<div
										class="overflow-hidden rounded-[1.65rem] border border-white/14 bg-[#101012] p-2 shadow-phone"
									>
										<Image
											src={homeScreen}
											alt="Sportykore welcome and sign-in flow."
											loading="lazy"
											decoding="async"
											sizes="(min-width: 1024px) 190px, 0px"
											class="rounded-[1.2rem]"
										/>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Editorial: cardless, Playfair sparingly (design.md) -->
		<section class="border-t border-surface-200 bg-white px-5 py-20 sm:px-8 lg:py-24">
			<div class="mx-auto max-w-2xl text-center">
				<p class="text-[11px] font-bold uppercase tracking-[0.26em] text-brand-600">Why Sportykore</p>
				<p class="mt-6 font-display text-2xl font-normal leading-snug text-slate-900 sm:text-[1.75rem]">
					Connect with leagues, follow live minutes, and read stats that stay legible when the game speeds up.
				</p>
				<p class="mx-auto mt-8 max-w-lg text-sm leading-7 text-slate-600">
					Built for grassroots football first — clear live context and league discovery that does not get buried.
				</p>
			</div>
		</section>

		<!-- Dark band: single device, app chrome -->
		<section class="bg-stripe-dark px-5 py-20 sm:px-8 lg:py-24">
			<div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2 lg:gap-20">
				<div class="max-w-lg space-y-5">
					<p class="text-[11px] font-bold uppercase tracking-[0.24em] text-accent-200/90">Matchday UI</p>
					<h2 class="font-display text-2xl font-bold leading-tight text-white sm:text-3xl">
						Reserve your place for launch.
					</h2>
					<p class="text-[0.9375rem] leading-8 text-white/68">
						One short form. We’ll reach you when the next wave opens for fans and organizers.
					</p>
				</div>
				<div class="flex justify-center lg:justify-end">
					<div
						class="w-full max-w-68 overflow-hidden rounded-4xl border border-white/12 bg-[#101012] p-3 shadow-phone sm:max-w-74"
					>
						<Image
							src={homeScreen}
							alt="Sportykore app home with striped header and tab navigation."
							loading="lazy"
							decoding="async"
							sizes="(min-width: 1024px) 300px, 85vw"
							class="rounded-[1.35rem]"
						/>
					</div>
				</div>
			</div>
		</section>

		<section class="border-t border-surface-200 bg-surface-50 px-5 py-14 sm:px-8">
			<div
				class="mx-auto flex max-w-4xl flex-col items-center justify-between gap-6 text-center sm:flex-row sm:text-left"
			>
				<p class="max-w-md text-sm leading-7 text-slate-600">
					<span class="font-semibold text-slate-900">Sportykore</span> — local football, clearer for everyone on the continent.
				</p>
				<a
					class="text-sm font-semibold text-brand-600 underline decoration-brand-200 underline-offset-4 transition hover:text-brand-700 hover:decoration-brand-400"
					href="#form"
				>
					Back to form
				</a>
			</div>
		</section>

		<footer class="border-t border-white/10 bg-stripe-dark px-5 py-9 sm:px-8">
			<div class="mx-auto flex max-w-6xl flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
				<p class="font-brand text-2xl text-accent-400">Sportykore</p>
				<p class="text-xs text-white/40">© {year} Sportykore</p>
			</div>
		</footer>
	</main>
</Layout>
