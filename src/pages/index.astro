---
import Layout from '../layouts/Layout.astro';
import LiveMatchCard from '../components/LiveMatchCard.astro';
import Ticker from '../components/Ticker.astro';
import PhoneFrame from '../components/PhoneFrame.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import WaitlistSection from '../components/WaitlistSection.astro';
import { homepageFaqEntries } from '../lib/faq';

import matchCenter from '../assets/screens/match-center.png';
import playerProfile from '../assets/screens/player-profile.png';
import manageLeagues from '../assets/screens/manage-leagues.png';
import joinLeague from '../assets/screens/join-league.png';

export const prerender = true;

const steps = [
	{
		title: 'Create your competition',
		text: 'Name it, set the season, add teams.',
	},
	{
		title: 'Invite players by link',
		text: 'Share one link in the team WhatsApp; players build their own profiles.',
	},
	{
		title: 'Run match day live',
		text: 'Score, minute, goals and assists, from one phone.',
	},
	{
		title: 'The table keeps itself',
		text: 'Standings and player stats update automatically after every result.',
	},
];

const showcase = [
	{
		image: matchCenter,
		alt: 'Sportykore live match center with big plus and minus score buttons, the running minute, and goal logging',
		title: 'Run the match like a broadcast.',
		text: 'Big +/− score buttons, the live minute, and scorers and assists logged as they happen — all from one phone at the pitch.',
	},
	{
		image: playerProfile,
		alt: 'Sportykore player profile showing per-season and career totals for goals, assists, fixtures, and cards',
		title: 'Every player gets a record that lasts.',
		text: 'Per-season numbers and career totals — goals, assists, fixtures, cards — a record that follows every player.',
	},
	{
		image: manageLeagues,
		alt: 'Sportykore competition management screen for creating, scheduling, and managing competitions',
		title: 'Your competition, in your pocket.',
		text: 'Create the competition, set the season, add teams, and manage every fixture from your phone.',
	},
	{
		image: joinLeague,
		alt: 'Sportykore join competition screen where a player pastes an invite code',
		title: 'Joining takes one code.',
		text: 'Your admin shares an invite link in the team WhatsApp. Paste the code, build your own profile, and you’re in.',
	},
];

const roles = [
	{
		title: 'Players',
		icon: 'player',
		points: [
			'A permanent profile — goals, assists, fixtures, and career totals.',
			'Join any competition with one invite code.',
			'Sign in with a one-time code — no passwords, ever.',
		],
		linkLabel: 'More for players',
		href: '/players',
	},
	{
		title: 'Coaches',
		icon: 'coach',
		points: [
			'Formation-aware lineups with proper positions.',
			'Substitutions that keep the pitch view accurate.',
			'Player development recorded automatically from live matches.',
		],
		linkLabel: 'More for coaches',
		href: '/players',
	},
	{
		title: 'Organizers',
		icon: 'organizer',
		points: [
			'Create a competition and add teams in minutes.',
			'Run match day live from one phone.',
			'Standings that update themselves after every result.',
		],
		linkLabel: 'More for organizers',
		href: '/organizers',
	},
];

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://sportykore.com';

const softwareApplicationSchema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Sportykore',
	applicationCategory: 'SportsApplication',
	operatingSystem: 'iOS, Android',
	description:
		'Sportykore — live match scoring, automatic standings, and permanent player profiles for grassroots football competitions in Nigeria. Join the waitlist for early access.',
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'NGN',
	},
	url: siteUrl,
	publisher: {
		'@type': 'Organization',
		name: 'Sportykore',
	},
};
---

<Layout
	title="Sportykore — Where local competitions gather"
	description="Live scores, automatic standings, and permanent player profiles for grassroots football competitions in Nigeria. Join the waitlist."
	pathname="/"
	structuredData={[softwareApplicationSchema]}
>
	<main id="main" class="overflow-x-clip">
		<!-- §5.1 Hero — the signature dark broadcast band -->
		<section class="bg-stripe-hero px-5 pb-16 pt-14 text-white sm:px-8 lg:pb-24 lg:pt-20">
			<div
				class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-x-14 gap-y-10 lg:grid-cols-2"
			>
				<div class="space-y-6">
					<p class="eyebrow hero-enter text-gold-soft" style="--enter-delay: 0ms">
						Looking after the little man
					</p>
					<h1 class="display-1 hero-enter text-balance" style="--enter-delay: 150ms">
						Where local competitions gather.
					</h1>
					<p
						class="hero-enter max-w-lg text-[1.0625rem] leading-relaxed text-white/75"
						style="--enter-delay: 300ms"
					>
						Live scores, standings that keep themselves, and player profiles that last — no more
						“wetin be the score?” in the group chat.
					</p>
				</div>

				<div class="hero-enter lg:col-start-2 lg:row-span-2 lg:row-start-1" style="--enter-delay: 450ms">
					<div class="mx-auto max-w-md">
						<LiveMatchCard />
					</div>
				</div>

				<div
					class="hero-enter flex flex-col gap-3 sm:flex-row sm:items-center lg:col-start-1"
					style="--enter-delay: 300ms"
				>
					<a href="#waitlist" class="btn-cta text-base">Join the waitlist</a>
					<a href="#how-it-works" class="btn-ghost-dark text-base">See how it works</a>
				</div>
			</div>
		</section>

		<!-- §5.2 Broadcast ticker (ambience) -->
		<Ticker />

		<!-- §5.3 How it works (light) -->
		<section id="how-it-works" class="scroll-mt-20 bg-chalk px-5 py-20 sm:px-8 lg:py-24">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-2xl" data-reveal>
					<p class="eyebrow text-purple">How it works</p>
					<h2 class="display-2 mt-3 text-ink">From grassroots competition to broadcast in four steps.</h2>
				</div>

				<ol class="mt-12 grid list-none grid-cols-1 gap-6 p-0 sm:grid-cols-2 lg:grid-cols-4">
					{
						steps.map((step, index) => (
							<li data-reveal data-reveal-delay={String(index * 100)}>
								<span class="flex h-10 w-10 items-center justify-center rounded-full bg-purple font-bold text-white">
									{index + 1}
								</span>
								<h3 class="mt-4 text-lg font-bold text-ink">{step.title}</h3>
								<p class="mt-2 text-[0.9375rem] leading-relaxed text-muted">{step.text}</p>
							</li>
						))
					}
				</ol>
			</div>
		</section>

		<!-- §5.4 App screens showcase (dark broadcast band) -->
		<section class="bg-stripe-dark px-5 py-20 text-white sm:px-8 lg:py-24">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-2xl" data-reveal>
					<p class="eyebrow text-gold-soft">Inside the app</p>
					<h2 class="display-2 mt-3 text-white">The same chrome, from pitch to phone.</h2>
				</div>

				<div class="mt-14 space-y-20 lg:space-y-24">
					{
						showcase.map((row, index) => (
							<div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
								<div
									class:list={['flex justify-center', index % 2 === 1 && 'lg:order-2']}
									data-reveal
								>
									<div data-parallax class="w-[70%] max-w-70 sm:max-w-72">
										<PhoneFrame src={row.image} alt={row.alt} />
									</div>
								</div>
								<div
									class:list={[index % 2 === 1 && 'lg:order-1']}
									data-reveal
									data-reveal-delay="100"
								>
									<h3 class="font-display text-2xl font-bold leading-tight sm:text-3xl">
										{row.title}
									</h3>
									<p class="mt-4 max-w-md leading-relaxed text-white/70">{row.text}</p>
								</div>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- §5.5 For every role (light) -->
		<section class="bg-chalk px-5 py-20 sm:px-8 lg:py-24">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-2xl" data-reveal>
					<p class="eyebrow text-purple">For every role</p>
					<h2 class="display-2 mt-3 text-ink">Built for the whole competition.</h2>
				</div>

				<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
					{
						roles.map((role, index) => (
							<article
								class="flex flex-col rounded-2xl bg-white p-6 shadow-card sm:p-7"
								data-reveal
								data-reveal-delay={String(index * 100)}
							>
								<span
									class="flex h-11 w-11 items-center justify-center rounded-full bg-purple-tint text-purple"
									aria-hidden="true"
								>
									{role.icon === 'player' && (
										<svg
											class="h-5.5 w-5.5"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
										>
											<circle cx="12" cy="8" r="4" />
											<path d="M4 21v-1a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v1" />
										</svg>
									)}
									{role.icon === 'coach' && (
										<svg
											class="h-5.5 w-5.5"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
										>
											<rect x="4" y="3" width="16" height="18" rx="2" />
											<path d="M9 3v2h6V3" />
											<circle cx="12" cy="11" r="2.5" />
											<path d="M8 17h8" />
										</svg>
									)}
									{role.icon === 'organizer' && (
										<svg
											class="h-5.5 w-5.5"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
										>
											<path d="M8 21h8" />
											<path d="M12 17v4" />
											<path d="M7 4h10v6a5 5 0 0 1-10 0V4Z" />
											<path d="M7 6H4a2 2 0 0 0 2 4h1" />
											<path d="M17 6h3a2 2 0 0 1-2 4h-1" />
										</svg>
									)}
								</span>
								<h3 class="mt-5 text-xl font-bold text-ink">{role.title}</h3>
								<ul class="mt-4 flex-1 space-y-3 text-[0.9375rem] leading-relaxed text-muted">
									{role.points.map((point) => (
										<li class="flex gap-2.5">
											<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gold-score" aria-hidden="true" />
											{point}
										</li>
									))}
								</ul>
								<a
									href={role.href}
									class="link-slide mt-6 inline-block self-start font-bold text-purple"
								>
									{role.linkLabel} →
								</a>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<!-- §5.6 FAQ preview (light) -->
		<section class="border-t border-ink/5 bg-chalk px-5 py-20 sm:px-8 lg:py-24">
			<div class="mx-auto max-w-3xl">
				<div class="max-w-2xl" data-reveal>
					<p class="eyebrow text-purple">Questions</p>
					<h2 class="display-2 mt-3 text-ink">Asked and answered.</h2>
				</div>

				<div class="mt-10" data-reveal>
					<FaqAccordion entries={homepageFaqEntries} />
				</div>

				<p class="mt-8" data-reveal>
					<a href="/faq" class="link-slide font-bold text-purple">All questions →</a>
				</p>
			</div>
		</section>

		<!-- §5.7 Waitlist CTA -->
		<WaitlistSection />
	</main>
</Layout>
