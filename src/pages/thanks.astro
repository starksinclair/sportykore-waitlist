---
import Layout from '../layouts/Layout.astro';
import PhoneFrame from '../components/PhoneFrame.astro';
import onboarding from '../assets/screens/onboarding.png';

export const prerender = true;
---

<Layout
	title="You’re on the list — Sportykore"
	description="Your details are in. Sportykore will email you when early access opens."
	pathname="/thanks"
	robots="noindex, follow"
	hideNav
>
	<main id="main" class="overflow-x-clip">
		<section class="bg-stripe-hero px-5 py-14 text-white sm:px-8 lg:py-20">
			<div
				class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-12 lg:grid-cols-[1.2fr_0.8fr]"
			>
				<div class="space-y-7">
					<p class="wordmark hero-enter text-4xl text-gold-score sm:text-5xl" style="--enter-delay: 0ms">
						Sportykore
					</p>
					<div class="max-w-xl space-y-4">
						<p class="eyebrow hero-enter text-gold-soft" style="--enter-delay: 150ms">
							You’re on the list
						</p>
						<h1 class="display-1 hero-enter text-balance" style="--enter-delay: 150ms">
							Thanks for joining the waitlist.
						</h1>
						<p
							class="hero-enter max-w-md text-[1.0625rem] leading-relaxed text-white/75"
							style="--enter-delay: 300ms"
						>
							You’re in line for early access as we onboard our first competitions.
						</p>
					</div>

					<div
						class="hero-enter max-w-xl rounded-2xl border border-white/12 bg-white/6 p-6 sm:p-7"
						style="--enter-delay: 450ms"
					>
						<p class="eyebrow text-gold-soft">What happens next</p>
						<ul class="mt-4 space-y-3 text-sm leading-relaxed text-white/75">
							<li class="flex gap-2.5">
								<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gold-score" aria-hidden="true"></span>
								We’ll email you when early access opens — no spam, just the invite.
							</li>
							<li class="flex gap-2.5">
								<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gold-score" aria-hidden="true"></span>
								Tell your competition admin and teammates — competitions get onboarded together.
							</li>
							<li class="flex gap-2.5">
								<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gold-score" aria-hidden="true"></span>
								Follow us on
								<a
									href="https://www.instagram.com/sportykore"
									class="link-slide font-semibold text-white hover:text-gold-soft"
									target="_blank"
									rel="noopener noreferrer"
								>Instagram</a>
								and
								<a
									href="https://x.com/sportykore"
									class="link-slide font-semibold text-white hover:text-gold-soft"
									target="_blank"
									rel="noopener noreferrer"
								>X</a>
								for updates.
							</li>
						</ul>
					</div>

					<a href="/" class="btn-ghost-dark hero-enter text-base" style="--enter-delay: 450ms">
						← Back to the site
					</a>
				</div>

				<div class="hero-enter flex justify-center lg:justify-end" style="--enter-delay: 450ms">
					<div class="w-[62%] max-w-64 sm:max-w-68">
						<PhoneFrame
							src={onboarding}
							alt="Sportykore app onboarding screen with a live match card"
							loading="eager"
							sizes="(min-width: 1024px) 272px, 62vw"
						/>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
