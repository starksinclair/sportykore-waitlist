---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import getStartedScreen from '../assets/screens/getstarted-screen.png';

export const prerender = true;
---

<Layout
	title="You’re on the list | Sportykore"
	description="Your details are in. Sportykore will reach out when the next wave of access opens."
	pathname="/thanks"
	robots="noindex, follow"
>
	<main class="overflow-x-clip">
		<section class="relative isolate min-h-svh bg-[#121212]">
			<div class="pointer-events-none absolute inset-0 hero-purple-wash"></div>
			<div class="pointer-events-none absolute inset-0 bg-linear-to-b from-black/25 to-black/35"></div>

			<div class="relative mx-auto grid min-h-svh max-w-6xl gap-10 px-5 py-10 sm:px-8 lg:grid-cols-[1fr_minmax(0,22rem)] lg:items-center lg:gap-14 lg:py-12">
				<div class="flex flex-col justify-center space-y-8">
					<p class="font-brand text-4xl text-accent-400 sm:text-5xl">Sportykore</p>
					<div class="max-w-xl space-y-4">
						<div class="flex items-center gap-2">
							<span class="h-2 w-2 rounded-full bg-live-red" aria-hidden="true"></span>
							<p class="text-[11px] font-bold uppercase tracking-[0.26em] text-accent-200/90">
								You’re on the list
							</p>
						</div>
						<h1 class="font-display text-4xl font-bold leading-[1.05] text-white sm:text-5xl">
							Thanks for joining the waitlist.
						</h1>
						<p class="max-w-md text-base leading-8 text-white/72">
							We’ll be in touch when the next wave opens for local organizers and fans. Keep your inbox and phone close.
						</p>
					</div>

					<div
						class="max-w-xl rounded-[1.75rem] border border-white/12 bg-white/[0.07] p-6 backdrop-blur-sm sm:p-7"
					>
						<p class="text-[11px] font-bold uppercase tracking-[0.2em] text-accent-200">What happens next</p>
						<p class="mt-3 text-sm leading-7 text-white/75">
							We will reach out once the mobile app is available for download.
						</p>
					</div>
				</div>

				<div class="flex items-center justify-center pb-6 lg:justify-end lg:pb-0">
					<div
						class="w-full max-w-[20rem] overflow-hidden rounded-4xl border border-white/12 bg-[#101012] p-3 shadow-phone lg:max-w-88"
					>
						<Image
							src={getStartedScreen}
							alt="Sportykore get started screen."
							loading="lazy"
							decoding="async"
							sizes="(min-width: 1024px) 22rem, 85vw"
							class="rounded-[1.35rem]"
						/>
					</div>
				</div>
			</div>
		</section>

		<SiteFooter secondaryHref="/" secondaryLabel="← Back to waitlist" />
	</main>
</Layout>
