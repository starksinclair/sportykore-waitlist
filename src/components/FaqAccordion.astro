---
import type { FaqEntry } from '../lib/faq';

interface Props {
	entries: FaqEntry[];
}

const { entries } = Astro.props;
---

<div class="space-y-3">
	{
		entries.map((entry) => (
			<details class="faq-item">
				<summary class="flex items-center justify-between gap-4 px-5 py-4 font-semibold text-ink sm:px-6">
					<span>{entry.question}</span>
					<svg
						class="faq-chevron h-5 w-5 shrink-0 text-purple"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="m6 9 6 6 6-6" />
					</svg>
				</summary>
				<p class="px-5 pb-5 leading-relaxed text-muted sm:px-6">{entry.answer}</p>
			</details>
		))
	}
</div>
