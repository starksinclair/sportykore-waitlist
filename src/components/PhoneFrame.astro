---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: ImageMetadata;
	alt: string;
	sizes?: string;
	loading?: 'eager' | 'lazy';
	class?: string;
}

const {
	src,
	alt,
	sizes = '(min-width: 1024px) 320px, 70vw',
	loading = 'lazy',
	class: className,
} = Astro.props;
---

<div class:list={['phone-frame', className]}>
	<Image
		src={src}
		alt={alt}
		sizes={sizes}
		widths={[280, 420, 640, 840]}
		loading={loading}
		decoding="async"
	/>
</div>
