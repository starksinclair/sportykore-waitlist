---
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import config from 'virtual:starlight/user-config';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const links = [
	{ href: '/players', label: 'Players' },
	{ href: '/organizers', label: 'Organizers' },
	{ href: '/docs', label: 'Docs' },
	{ href: '/faq', label: 'FAQ' },
];
---

<div class="sk-docs-header">
	<a href="/" class="sk-docs-wordmark" translate="no">Sportykore</a>
	<nav class="sk-docs-links" aria-label="Main site">
		{
			links.map((link) => (
				<a href={link.href} aria-current={link.href === '/docs' ? 'page' : undefined}>
					{link.label}
				</a>
			))
		}
	</nav>
	<div class="sk-docs-search print:hidden">
		{shouldRenderSearch && <Search />}
	</div>
	<div class="sk-docs-actions print:hidden">
		<div class="sk-docs-socials">
			<SocialIcons />
		</div>
		<ThemeSelect />
		<LanguageSelect />
		<a href="/#waitlist" class="sk-docs-cta">Join the waitlist</a>
	</div>
</div>
