---
import '../styles/legal.css';
import SiteFooter from './SiteFooter.astro';

interface Props {
	pageTitle: string;
	lead?: string;
	bodyHtml: string;
}

const { pageTitle, lead, bodyHtml } = Astro.props;
---

<main class="overflow-x-clip">
	<section class="relative isolate bg-[#121212]">
		<div class="pointer-events-none absolute inset-0 hero-purple-wash"></div>
		<div class="pointer-events-none absolute inset-0 bg-linear-to-b from-black/30 via-transparent to-black/20"></div>

		<div class="relative mx-auto max-w-6xl px-5 py-10 sm:px-8 sm:py-12">
			<a
				class="inline-flex items-center gap-2 text-sm font-semibold text-accent-200/90 transition hover:text-accent-200"
				href="/"
			>
				<span aria-hidden="true">←</span> Back to waitlist
			</a>
			<div class="mt-8 max-w-2xl space-y-4">
				<p class="font-brand text-4xl text-accent-400 sm:text-5xl">Sportykore</p>
				<h1 class="font-display text-3xl font-bold leading-tight text-white sm:text-4xl">
					{pageTitle}
				</h1>
				{
					lead ? (
						<p class="max-w-xl text-base leading-relaxed text-white/72">{lead}</p>
					) : null
				}
			</div>
		</div>
	</section>

	<section class="bg-surface-50 px-5 py-12 sm:px-8 sm:py-16">
		<article class="legal-document mx-auto max-w-3xl" set:html={bodyHtml} />
	</section>

	<SiteFooter />
</main>
