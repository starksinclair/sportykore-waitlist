---
import '../styles/legal.css';
import WaitlistSection from './WaitlistSection.astro';

interface Props {
	pageTitle: string;
	lead?: string;
	bodyHtml: string;
}

const { pageTitle, lead, bodyHtml } = Astro.props;
---

<main id="main" class="overflow-x-clip">
	<section class="bg-stripe-hero px-5 pb-12 pt-12 text-white sm:px-8 lg:pb-14 lg:pt-16">
		<div class="mx-auto max-w-6xl">
			<div class="max-w-2xl space-y-4">
				<h1 class="display-1 text-balance">{pageTitle}</h1>
				{lead ? <p class="max-w-xl text-base leading-relaxed text-white/72">{lead}</p> : null}
			</div>
		</div>
	</section>

	<section class="bg-chalk px-5 py-12 sm:px-8 sm:py-16">
		<article class="legal-document mx-auto max-w-3xl" set:html={bodyHtml} />
	</section>

	<WaitlistSection />
</main>
