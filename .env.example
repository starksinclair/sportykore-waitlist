# Google Sheets waitlist integration (server-side only).
# Local: copy to `.env`. Production: add the same keys in Vercel → Project → Settings → Environment Variables.
# Never commit `.env`.

# --- Google auth (pick ONE approach) ---

# Option A — Base64 (recommended on Vercel: avoids broken JSON / quoting in the dashboard).
# macOS: base64 -i your-key.json | tr -d '\n'
# Paste the single line as the value (no quotes).
GOOGLE_SERVICE_ACCOUNT_BASE64=

# Option B — raw JSON (one line). Can be fragile in Vercel UI if the JSON contains double quotes.
GOOGLE_SERVICE_ACCOUNT=

# Option C — split (works well in local `.env`):
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# --- Sheet target ---

# From URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Exact tab name (case-sensitive), e.g. Waitlist. Share the sheet with the service account email as Editor.
GOOGLE_SHEETS_SHEET_NAME=
