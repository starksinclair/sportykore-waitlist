# Google Sheets waitlist integration (server-side only — set in Vercel project settings for production).
# Copy to `.env` and fill in real values. Never commit `.env`.

# Option A — one variable (easiest on Vercel): paste the entire Google Cloud service account JSON as one line.
# Example: GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...", ...}
GOOGLE_SERVICE_ACCOUNT=

# Option B — split vars (fine for local `.env`): omit GOOGLE_SERVICE_ACCOUNT and use these instead.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Spreadsheet ID from the sheet URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Tab name for append range, e.g. Waitlist
GOOGLE_SHEETS_SHEET_NAME=
