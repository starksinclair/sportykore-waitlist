# Google Sheets waitlist integration (server-side only — set in Vercel project settings for production).
# Copy to `.env` and fill in real values. Never commit `.env`.

# Service account email from the Google Cloud JSON key (e.g. sheets-writer@project.iam.gserviceaccount.com)
GOOGLE_CLIENT_EMAIL=

# Private key from the same JSON — single line with literal \n where line breaks were (the app replaces \\n with newlines)
GOOGLE_PRIVATE_KEY=

# Spreadsheet ID from the sheet URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Tab name for append range, e.g. Waitlist
GOOGLE_SHEETS_SHEET_NAME=
